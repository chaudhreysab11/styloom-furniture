{
    "framework": null,
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.4",
            "maxDuration": 30,
            "excludeFiles": "packages/*/src/Resources/assets/**"
        }
    },
    "routes": [
        { "handle": "filesystem" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "crons": [
        {
            "path": "/cron/schedule",
            "schedule": "* * * * *"
        }
    ]
}
