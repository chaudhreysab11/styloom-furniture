{
    "framework": null,
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.8.0",
            "maxDuration": 30,
            "excludeFiles": "packages/*/src/Resources/assets/**"
        }
    },
    "routes": [
        { "src": "^/(build|themes|fonts|forge)/(.*)$", "dest": "/public/$1/$2" },
        { "src": "^/(favicon\\.ico|robots\\.txt)$", "dest": "/public/$1" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "crons": [
        {
            "path": "/cron/schedule",
            "schedule": "0 0 * * *"
        }
    ]
}
